# Optional server-only key used to enrich /api/intelligence.
# Without a key, AetherGlobe still returns a source-backed Open-Meteo/USGS summary.
# Never expose this value with a VITE_ prefix.
OPENAI_API_KEY=

# Optional OpenAI model override. The API defaults to gpt-5.2 and falls back
# to gpt-5-mini when the configured model is unavailable.
OPENAI_MODEL=gpt-5.2

# Optional local dump1090 receiver. This private-network URL works only when
# AetherGlobe's Express server is running on the same LAN as the receiver.
DUMP1090_AIRCRAFT_URL=http://192.168.0.168/dump1090/data/aircraft.json
DUMP1090_MAX_POSITION_AGE_SECONDS=20

# Aviationstack is used for on-demand flight lookup and as a sampled live-position
# fallback when the configured dump1090 receiver cannot be reached. Replace only
# the placeholder in your private .env.local file. Never commit the real key.
AVIATIONSTACK_API_KEY=PASTE_YOUR_AVIATIONSTACK_KEY_HERE
AVIATIONSTACK_BASE_URL=https://api.aviationstack.com/v1
AVIATIONSTACK_TRAFFIC_CACHE_SECONDS=900
AVIATIONSTACK_MAX_LIVE_AGE_SECONDS=1800

# Local Express runtime configuration
PORT=3000
NODE_ENV=development
