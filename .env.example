# Optional local dump1090 receiver. This private-network URL works only when
# AetherGlobe's Express server is running on the same LAN as the receiver.
DUMP1090_AIRCRAFT_URL=http://192.168.0.168/dump1090/data/aircraft.json
DUMP1090_MAX_POSITION_AGE_SECONDS=20

# Optional on-demand commercial flight lookup. Replace only the placeholder
# in your private .env.local file. Never commit the real key or use VITE_.
AVIATIONSTACK_API_KEY=PASTE_YOUR_AVIATIONSTACK_KEY_HERE
AVIATIONSTACK_BASE_URL=https://api.aviationstack.com/v1

# Live maritime traffic through AISstream. The API key must stay server-side.
# The persistent WebSocket works in the local Express runtime. A public
# serverless deployment needs a separate always-on relay.
AISSTREAM_API_KEY=PASTE_YOUR_AISSTREAM_KEY_HERE
AISSTREAM_URL=wss://stream.aisstream.io/v0/stream
AISSTREAM_MAX_POSITION_AGE_SECONDS=300

# Local Express runtime configuration
PORT=3000
NODE_ENV=development
