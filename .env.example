# Optional server-only key used to enrich /api/intelligence.
# Without a key, AetherGlobe still returns a source-backed Open-Meteo/USGS summary.
# Never expose this value with a VITE_ prefix.
GEMINI_API_KEY=

# Optional stable Gemini model override. The server falls back to gemini-2.5-flash.
GEMINI_MODEL=gemini-3.5-flash

# Runtime configuration
PORT=3000
NODE_ENV=development
