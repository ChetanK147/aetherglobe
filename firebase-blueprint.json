{
  "entities": {
    "User": {
      "title": "User",
      "description": "Authenticated user profile synchronized after Google sign-in",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": ["string", "null"], "format": "email" },
        "displayName": { "type": ["string", "null"] },
        "createdAt": { "type": "object", "description": "Firestore server timestamp" },
        "updatedAt": { "type": "object", "description": "Firestore server timestamp" }
      },
      "required": ["uid", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Private profile readable and writable only by the authenticated user."
    }
  }
}
