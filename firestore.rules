rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string
        && id.size() <= 128
        && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function validUserCreate(userId) {
      return request.resource.data.keys().hasOnly([
          'uid', 'email', 'displayName', 'createdAt', 'updatedAt'
        ])
        && request.resource.data.keys().hasAll(['uid', 'createdAt', 'updatedAt'])
        && request.resource.data.uid == userId
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function validUserUpdate() {
      return request.resource.data.uid == resource.data.uid
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['email', 'displayName', 'updatedAt']);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(userId) && validUserCreate(userId);
      allow update: if isOwner(userId) && validUserUpdate();
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
